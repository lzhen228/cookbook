# .env.example — 本文件提交至 git，.env.local 不提交

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scrm
DB_USERNAME=scrm_user
DB_PASSWORD=REPLACE_ME

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_ME

# Kafka 配置
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# JWT 配置
JWT_SECRET=REPLACE_ME
JWT_ACCESS_TOKEN_TTL_SECONDS=7200
JWT_REFRESH_TOKEN_TTL_SECONDS=604800

# MinIO 配置
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=REPLACE_ME
MINIO_SECRET_KEY=REPLACE_ME
MINIO_BUCKET=scrm-reports

# 第三方 API
EXT_QICHA_API_KEY=REPLACE_ME
EXT_QICHA_BASE_URL=https://api.qichacha.com

# 通知
NOTIFY_WXBOT_WEBHOOK_URL=REPLACE_ME

# 应用
APP_ENV=dev
APP_LOG_LEVEL=INFO

# Dev Skills SDK
API_HOST=http://localhost:8080
REQUEST_TIMEOUT_MS=10000
MAX_RETRIES=3
